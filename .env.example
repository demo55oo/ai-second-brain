# ---------------------------------------------------------------------------
# Copy to `.env.local` (or set in Vercel / Netlify). Never commit secrets.
# ---------------------------------------------------------------------------

# --- Brain engine ------------------------------------------------------------
# api  = deployable path (Anthropic / AI Gateway) — DEFAULT, works on Vercel/Netlify
# cli  = local Claude Code CLI spawn (Mac/Linux desktop only)
BRAIN_ENGINE=api

# --- LLM (required for API brain) --------------------------------------------
# Prefer Vercel AI Gateway (one key for chat + embeddings):
AI_GATEWAY_API_KEY=
# Or Anthropic direct:
ANTHROPIC_API_KEY=
# Model id. Gateway style: anthropic/claude-sonnet-4-6
AI_MODEL=anthropic/claude-sonnet-4-6

# --- Embeddings (required to index / search uploads) -------------------------
# Gateway covers openai/text-embedding-3-small when AI_GATEWAY_API_KEY is set.
# Otherwise set OpenAI direct:
OPENAI_API_KEY=

# --- Supabase (required for vault upload + search + brand kits) --------------
# 1. Create a project at https://supabase.com
# 2. Run SQL from supabase/migrations/0007_vault_vectors.sql
#    (and 0009_brand_kits.sql if you use branding)
# 3. Paste URL + keys from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: local Obsidian disk path (dev only; prefer Supabase upload) ---
VAULT_PATH=
VAULT_EXCLUDE=.obsidian,.trash,node_modules,.git

# --- Optional: Vercel Blob fallback (legacy vault sync) ----------------------
BLOB_READ_WRITE_TOKEN=

# --- Optional: Claude CLI path (only when BRAIN_ENGINE=cli) ------------------
CLAUDE_BIN=
JARVIS_CODE_MODEL=
JARVIS_CODE_MAX_TURNS=
JARVIS_CODE_BASE_URL=http://localhost:3000

# --- Optional: image gen / leads / Zapier (not needed for AI Brain) ----------
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high
APIFY_TOKEN=
ZAPIER_MCP_URL=
ZAPIER_MCP_TOKEN=

APP_URL=http://localhost:3000
