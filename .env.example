# ---------------------------------------------------------------------------
# Copy to `.env.local` (or set in Vercel / Netlify). Never commit secrets.
# ---------------------------------------------------------------------------

# --- Brain engine ------------------------------------------------------------
# Defaults to api in code + on Vercel/Netlify. Only set this to force cli locally.
# BRAIN_ENGINE=api

# --- LLM (required for AI Brain chat) ----------------------------------------
# Prefer Vercel AI Gateway:
AI_GATEWAY_API_KEY=
# Or Anthropic direct:
ANTHROPIC_API_KEY=
# Optional — hosts default this; override if you want another model
# AI_MODEL=anthropic/claude-sonnet-4-6

# --- Supabase (OPTIONAL — only for vault upload / brand kits) ----------------
# Chat works without these using content/knowledge/* bundled docs.
# If you add them later, run supabase/migrations/0007_vault_vectors.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Embeddings (OPTIONAL — only when indexing vault uploads) ----------------
# Needed if you use vault upload and gateway has no OpenAI embeddings route.
OPENAI_API_KEY=

# --- Optional: local Obsidian disk path (dev only) ---------------------------
VAULT_PATH=
VAULT_EXCLUDE=.obsidian,.trash,node_modules,.git

# --- Optional: Vercel Blob fallback (legacy) ---------------------------------
BLOB_READ_WRITE_TOKEN=

# --- Optional: Claude CLI path (only when BRAIN_ENGINE=cli) ------------------
CLAUDE_BIN=
JARVIS_CODE_MODEL=
JARVIS_CODE_MAX_TURNS=
JARVIS_CODE_BASE_URL=http://localhost:3000

# --- Optional: image gen / leads / Zapier (not needed for AI Brain) ----------
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high
APIFY_TOKEN=
ZAPIER_MCP_URL=
ZAPIER_MCP_TOKEN=

APP_URL=http://localhost:3000
